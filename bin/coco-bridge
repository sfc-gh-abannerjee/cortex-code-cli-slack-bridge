#!/usr/bin/env bash
# coco-bridge — convenience wrapper for the Cortex Code Slack Bridge
#
# Usage:
#   coco-bridge start              Start the bridge bot in the background
#   coco-bridge stop               Stop the bridge bot
#   coco-bridge status             Check if the bridge is running
#   coco-bridge send "message"     Send a plain notification
#   coco-bridge send "msg" --type status  Send color-coded (status|success|warning|error)
#   coco-bridge confirm "question" Send confirmation buttons (blocks until response)
#   coco-bridge logs               Tail the bridge log
#   coco-bridge inbox              Show current inbox contents
#   coco-bridge history [N]        Show last N history entries (default: 20)

set -euo pipefail

BRIDGE_DIR="$HOME/.cortex-slack-bridge"
HISTORY_FILE="$BRIDGE_DIR/history.jsonl"
PID_FILE="$BRIDGE_DIR/bridge.pid"
LOG_FILE="$BRIDGE_DIR/bridge.log"
SESSION_ID="${CORTEX_SESSION_ID:-default}"
INBOX_FILE="$BRIDGE_DIR/inbox_${SESSION_ID}.json"
# Legacy fallback for session_id=default
if [[ "$SESSION_ID" == "default" ]]; then
    INBOX_FILE="$BRIDGE_DIR/inbox.json"
fi

# Resolve the Python that has cortex-slack-bridge installed.
# Prefer the venv in the project dir, fall back to system python3.
PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
if [[ -x "$PROJECT_DIR/.venv/bin/python" ]]; then
    PYTHON="$PROJECT_DIR/.venv/bin/python"
else
    PYTHON="python3"
fi

_ensure_dir() { mkdir -p "$BRIDGE_DIR"; }

_is_running() {
    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid=$(<"$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
        # Stale PID file
        rm -f "$PID_FILE"
    fi
    return 1
}

cmd_start() {
    _ensure_dir
    if _is_running; then
        echo "Bridge already running (PID $(<"$PID_FILE"))"
        return 0
    fi
    echo "Starting Cortex Code Slack Bridge..."
    # Use Python to launch the bridge in a new session (start_new_session=True calls
    # os.setsid() so the child gets its own process group — it survives even when the
    # parent shell is killed by a timeout or SIGKILL, unlike nohup+disown alone).
    local launched_pid
    launched_pid=$(python3 -c "
import os, subprocess, sys
log = open('$LOG_FILE', 'a')
p = subprocess.Popen(
    [sys.executable, '-m', 'cortex_slack_bridge.bridge'],
    stdout=log, stderr=log, stdin=open('/dev/null'),
    start_new_session=True,
)
print(p.pid)
")
    # Wait for the bridge to connect (writes its own PID file and Socket Mode session)
    local attempts=0
    while [[ $attempts -lt 15 ]]; do
        sleep 1
        attempts=$((attempts + 1))
        if [[ -f "$PID_FILE" ]] && kill -0 "$(<"$PID_FILE")" 2>/dev/null; then
            echo "Bridge started (PID $(<"$PID_FILE"))"
            echo "Logs: $LOG_FILE"
            return 0
        fi
        if ! kill -0 "$launched_pid" 2>/dev/null; then
            echo "Bridge process exited unexpectedly. Check logs:" >&2
            tail -20 "$LOG_FILE" >&2
            return 1
        fi
    done
    if kill -0 "$launched_pid" 2>/dev/null; then
        echo "$launched_pid" > "$PID_FILE"
        echo "Bridge started (PID $launched_pid)"
        echo "Logs: $LOG_FILE"
    else
        echo "Bridge failed to start. Check logs:" >&2
        tail -20 "$LOG_FILE" >&2
        return 1
    fi
}

cmd_stop() {
    if ! _is_running; then
        echo "Bridge is not running."
        return 0
    fi
    local pid
    pid=$(<"$PID_FILE")
    echo "Stopping bridge (PID $pid)..."
    kill "$pid" 2>/dev/null || true
    # Wait for clean exit
    for _ in $(seq 1 10); do
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$PID_FILE"
            echo "Bridge stopped."
            return 0
        fi
        sleep 0.5
    done
    # Force kill
    kill -9 "$pid" 2>/dev/null || true
    rm -f "$PID_FILE"
    echo "Bridge force-stopped."
}

cmd_status() {
    if _is_running; then
        echo "Bridge is running (PID $(<"$PID_FILE"))"
    else
        echo "Bridge is not running."
    fi
}

cmd_send() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: coco-bridge send \"message\" [--type status|success|warning|error]" >&2
        return 1
    fi
    local message="$1"
    shift
    "$PYTHON" -m cortex_slack_bridge.notify --session "$SESSION_ID" "$@" "$message"
}

cmd_confirm() {
    if [[ $# -lt 1 ]]; then
        echo "Usage: coco-bridge confirm \"question\" [--id ID] [--timeout SECS]" >&2
        return 1
    fi
    local question="$1"
    shift
    "$PYTHON" -m cortex_slack_bridge.notify --confirm --session "$SESSION_ID" "$question" "$@"
}

cmd_logs() {
    if [[ -f "$LOG_FILE" ]]; then
        tail -f "$LOG_FILE"
    else
        echo "No log file yet. Start the bridge first."
    fi
}

cmd_inbox() {
    if [[ -f "$INBOX_FILE" ]]; then
        cat "$INBOX_FILE"
    else
        echo "[]"
    fi
}

cmd_history() {
    local n="${1:-20}"
    if [[ ! -f "$HISTORY_FILE" ]]; then
        echo "No history yet."
        return 0
    fi
    tail -n "$n" "$HISTORY_FILE" | "$PYTHON" -m json.tool --no-ensure-ascii 2>/dev/null || tail -n "$n" "$HISTORY_FILE"
}

cmd_setup_keychain() {
    local config_file="$BRIDGE_DIR/config.json"
    local app_token="" bot_token="" user_id=""

    if [[ -f "$config_file" ]]; then
        echo "Found config.json -- migrating tokens to macOS Keychain..."
        app_token=$("$PYTHON" -c "import json; print(json.load(open('$config_file')).get('app_token',''))")
        bot_token=$("$PYTHON" -c "import json; print(json.load(open('$config_file')).get('bot_token',''))")
        user_id=$("$PYTHON" -c "import json; print(json.load(open('$config_file')).get('user_id',''))")
    else
        echo "No config.json found. Enter tokens manually."
        read -rp "App token (xapp-...): " app_token
        read -rp "Bot token (xoxb-...): " bot_token
        read -rp "User ID (U...): " user_id
    fi

    local ok=true
    for pair in "app_token:$app_token" "bot_token:$bot_token" "user_id:$user_id"; do
        local key="${pair%%:*}"
        local val="${pair#*:}"
        if [[ -z "$val" ]]; then
            echo "  Skipping $key (empty)"
            continue
        fi
        if security add-generic-password -s coco-slack-bridge -a "$key" -w "$val" -U 2>/dev/null; then
            echo "  Stored $key in Keychain"
        else
            echo "  Failed to store $key" >&2
            ok=false
        fi
    done

    if [[ "$ok" == true && -f "$config_file" ]]; then
        echo ""
        read -rp "Delete config.json (tokens are now in Keychain)? [y/N] " confirm
        if [[ "$confirm" =~ ^[Yy] ]]; then
            mv "$config_file" "${config_file}.bak"
            echo "  Moved to config.json.bak"
        else
            echo "  Kept config.json (Keychain takes priority over it)"
        fi
    fi

    echo "Done. Tokens will be read from: env var > Keychain > config.json"
}

cmd_clear_keychain() {
    echo "Removing Slack bridge tokens from macOS Keychain..."
    for key in app_token bot_token user_id; do
        if security delete-generic-password -s coco-slack-bridge -a "$key" 2>/dev/null; then
            echo "  Removed $key"
        else
            echo "  $key not found in Keychain"
        fi
    done
    echo "Done."
}

# --- Main dispatch ---------------------------------------------------------
case "${1:-help}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    status)  cmd_status ;;
    send)    shift; cmd_send "$@" ;;
    confirm) shift; cmd_confirm "$@" ;;
    logs)    cmd_logs ;;
    inbox)   cmd_inbox ;;
    history) shift; cmd_history "$@" ;;
    setup-keychain) cmd_setup_keychain ;;
    clear-keychain) cmd_clear_keychain ;;
    help|*)
        echo "coco-bridge — Cortex Code Slack Bridge"
        echo ""
        echo "Commands:"
        echo "  start              Start the bridge bot in the background"
        echo "  stop               Stop the bridge bot"
        echo "  status             Check if the bridge is running"
        echo "  send \"message\"     Send a plain notification"
        echo "  confirm \"question\" Send Approve/Deny buttons and wait for response"
        echo "  logs               Tail the bridge log"
        echo "  inbox              Show current inbox contents"
        echo "  history [N]        Show last N history entries (default: 20)"
        echo "  setup-keychain     Store tokens in macOS Keychain (migrate from config.json)"
        echo "  clear-keychain     Remove tokens from macOS Keychain"
        ;;
esac
